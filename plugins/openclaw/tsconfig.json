{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		// strict: true — plugin boundary is the only place we control the
		// message shape that crosses into OpenClaw. Loose types here let bad
		// shapes flow silently (see issue #17). Keep this strict.
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowJs": false,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
