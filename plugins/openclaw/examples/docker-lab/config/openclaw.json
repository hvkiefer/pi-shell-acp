{
	"meta": {
		"name": "pi-shell-acp OpenClaw Docker Lab",
		"description": "Minimal repro config for OpenClaw 2026.5.18 + pi-shell-acp plugin + Telegram direct delivery. Replace placeholder Telegram values before use."
	},
	"gateway": {
		"host": "0.0.0.0",
		"port": 18789
	},
	"plugins": {
		"allow": ["pi-shell-acp", "telegram"],
		"load": {
			"paths": ["/home/node/repos/gh/pi-shell-acp/plugins/openclaw"]
		},
		"entries": {
			"telegram": {
				"enabled": true,
				"config": {}
			},
			"pi-shell-acp": {
				"enabled": true,
				"config": {
					"spawnTimeoutSeconds": 600
				}
			}
		}
	},
	"channels": {
		"telegram": {
			"enabled": true,
			"dmPolicy": "pairing",
			"groupPolicy": "allowlist",
			"streaming": {
				"mode": "partial"
			},
			"botToken": "REPLACE_WITH_TELEGRAM_BOT_TOKEN",
			"allowFrom": ["REPLACE_WITH_TELEGRAM_USER_ID"],
			"accounts": {
				"bbot": {
					"name": "B",
					"enabled": true,
					"dmPolicy": "pairing",
					"groupPolicy": "allowlist",
					"streaming": {
						"mode": "partial"
					},
					"botToken": "REPLACE_WITH_TELEGRAM_BOT_TOKEN",
					"allowFrom": ["REPLACE_WITH_TELEGRAM_USER_ID"]
				}
			}
		}
	},
	"messages": {
		"ackReactionScope": "group-mentions",
		"groupChat": {
			"visibleReplies": "message_tool"
		}
	},
	"agents": {
		"defaults": {
			"workspace": "/home/node/.openclaw/workspace-bbot",
			"model": {
				"primary": "pi-shell-acp/claude-opus-4-7",
				"fallbacks": []
			},
			"models": {
				"pi-shell-acp/claude-sonnet-4-6": {},
				"pi-shell-acp/claude-opus-4-7": {},
				"pi-shell-acp/gpt-5.4": {},
				"pi-shell-acp/gpt-5.5": {},
				"pi-shell-acp/gemini-3.1-pro-preview": {}
			}
		},
		"list": [
			{
				"id": "bbot",
				"name": "bbot",
				"workspace": "/home/node/.openclaw/workspace-bbot",
				"agentDir": "/home/node/.openclaw/agents/bbot/agent",
				"model": {
					"primary": "pi-shell-acp/claude-opus-4-7",
					"fallbacks": []
				},
				"models": {}
			}
		]
	}
}
